services:
  traefik:
    container_name: posbox-proxy
    image: traefik:v3.7
    restart: unless-stopped
    command:
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--entrypoints.websecure.address=:443"
      - "--providers.file.filename=/etc/traefik/conf.yml"
      - "--providers.file.watch=true"
    ports:
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - "{{ posbox_dir }}/traefik.yml:/etc/traefik/conf.yml:ro"
      - "{{ cert_dir }}:{{ cert_dir }}:ro"
    logging:
      driver: "journald"
      options:
        tag: "posbox-proxy"

  posbox:
    container_name: posbox
    image: ghcr.io/superquinquin-sur-deule/docker-posbox:latest
    restart: unless-stopped
    environment:
      POSTGRES_HOST: pgsql
      POSTGRES_USER: ${POSTGRES_USER:-odoo}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-odoo}
      ODOO_MODULES: hw_proxy,hw_escpos
    volumes:
      - /dev/bus/usb:/dev/bus/usb
      - /etc/localtime:/etc/localtime:ro
    logging:
      driver: "journald"
      options:
        tag: "posbox"
    tty: true
    privileged: true
    healthcheck:
      test: ["CMD", "/healthcheck.py"]
    depends_on:
      pgsql:
        condition: service_healthy
    labels:
      - "traefik.enable=true"
      - "traefik.http.services.posbox.loadbalancer.server.port=8069"
      - "traefik.http.routers.posbox-api.rule=Host(`localhost`) && PathPrefix(`/hw_proxy`)"
      - "traefik.http.routers.posbox-api.entrypoints=websecure"
      - "traefik.http.routers.posbox-api.tls=true"
      - "traefik.http.routers.posbox-status.rule=Host(`localhost`) && Path(`/`)"
      - "traefik.http.routers.posbox-status.middlewares=to-status"
      - "traefik.http.routers.posbox-status.entrypoints=websecure"
      - "traefik.http.routers.posbox-status.tls=true"
      - "traefik.http.middlewares.to-status.replacepath.path=/hw_proxy/status"

  pgsql:
    container_name: posbox-db
    image: postgres:13-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-odoo}
      POSTGRES_USER: ${POSTGRES_USER:-odoo}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-odoo}
      PGDATA: /var/lib/pgsql/data
    volumes:
      - data:/var/lib/pgsql/data
    logging:
      driver: "journald"
      options:
        tag: "posbox-db"
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "${POSTGRES_USER:-odoo}"]

volumes:
  data:
